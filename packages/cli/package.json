{
  "name": "@that-yolanda/yo-toolkits",
  "version": "0.2.12",
  "type": "module",
  "description": "个人 CLI 工具集合 — 插件式 (bin: yo + 框架运行时)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/that-yolanda/yo-toolkits.git",
    "directory": "packages/cli"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "yo": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "chalk": "^5.4.0",
    "execa": "^9.5.2",
    "jiti": "^2.4.2",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/which": "^3.0.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
