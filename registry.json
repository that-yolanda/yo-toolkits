{
  "version": "1.0.0",
  "repo": "that-yolanda/yo-toolkits",
  "plugins": {
    "gif": {
      "name": "gif",
      "version": "1.0.0",
      "description": "视频转 GIF 动图",
      "subdir": "packages/plugins/gif",
      "deps": [
        "ffmpeg",
        "ffprobe"
      ]
    },
    "wiki": {
      "name": "wiki",
      "version": "1.0.0",
      "description": "本地知识库管理(搜索/添加/更新知识原子)",
      "subdir": "packages/plugins/wiki",
      "env": [
        "WIKI_DIR"
      ]
    },
    "word-count": {
      "name": "word-count",
      "version": "1.0.0",
      "description": "中英文字数统计",
      "subdir": "packages/plugins/word-count"
    }
  }
}
