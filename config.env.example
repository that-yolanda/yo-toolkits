# yo-toolkits 配置示例
#
# 配置优先级:进程环境变量(process.env) > 配置文件
# 配置文件位置(统一根,与 yolanda-skills 的 YO_CONFIG_HOME 一致):
#   macOS / Linux:  ~/.local/share/yo/config.json
#   Windows:        %LOCALAPPDATA%\yo\config.json
# macOS/Linux 支持 XDG_DATA_HOME 覆盖根目录。
# 配置文件用 JSON 格式,例如:
#   { "WIKI_DIR": "/Users/yolanda/Documents/wiki" }
#
# 注:yolanda-skills 的环境变量(WIKI_DIR 等)写在同目录的 config.env,
# 由 shell source 生效;yo 工具的 config.json 与之分文件共存于统一根。
# 各插件所需的环境变量在 index.ts 的 Command.env 声明,
# 并由 gen:registry 同步进 registry.json 的 env 字段。

# ── wiki 插件(后续迁移) ──
# 本地知识库目录
WIKI_DIR=~/Documents/wiki

# ── tts 插件(后续迁移):火山引擎豆包 TTS ──
# TTS_APP_ID=
# TTS_ACCESS_KEY=
# TTS_RESOURCE_ID=seed-tts-2.0

# ── stt 插件(后续迁移):whisper.cpp ──
# WHISPER_MODEL=~/.cache/whisper.cpp/models/ggml-base.bin
# WHISPER_LANG=zh

# ── live-translate 插件(后续迁移):ollama ──
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b
