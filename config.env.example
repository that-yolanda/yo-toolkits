# yo-toolkits 配置示例
#
# 配置优先级:进程环境变量(process.env) > ~/.yo/config.json
# 即:导出为环境变量可覆盖配置文件。
# 配置文件用 JSON 格式,例如 ~/.yo/config.json:
#   { "WIKI_DIR": "/Users/yolanda/Documents/wiki" }

# ── wiki 插件(后续迁移) ──
# 本地知识库目录
WIKI_DIR=~/Documents/wiki

# ── tts 插件(后续迁移):火山引擎豆包 TTS ──
# TTS_APP_ID=
# TTS_ACCESS_KEY=
# TTS_RESOURCE_ID=seed-tts-2.0

# ── stt 插件(后续迁移):whisper.cpp ──
# WHISPER_MODEL=~/.cache/whisper.cpp/models/ggml-base.bin
# WHISPER_LANG=zh

# ── live-translate 插件(后续迁移):ollama ──
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b
